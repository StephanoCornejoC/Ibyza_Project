# ═════════════════════════════════════════════════════════════════════════════
# IBYZA Backend — Variables de entorno
# ═════════════════════════════════════════════════════════════════════════════
#
# 1. Copiar este archivo a `.env` (no se commitea):
#       cp .env.example .env
#
# 2. Para DESARROLLO local: las variables ya tienen defaults razonables.
#    Solo necesitas RESEND_API_KEY y CULQI_*_KEY si quieres probar
#    integraciones reales; sin ellas, los emails se imprimen en consola
#    y los pagos Culqi simulan errores.
#
# 3. Para PRODUCCIÓN (Render/Railway): NO uses este archivo. Configura cada
#    variable directamente en el dashboard del proveedor.
# ═════════════════════════════════════════════════════════════════════════════


# ─── Django ───────────────────────────────────────────────────────────────────
# SECRET_KEY: en producción usar una clave aleatoria de 50+ caracteres.
# Render la genera automáticamente con `generateValue: true`.
SECRET_KEY=genera-una-clave-segura-aqui

# DEBUG: True en desarrollo, False en producción (siempre).
DEBUG=True

# ALLOWED_HOSTS: separados por coma, sin espacios.
# Producción: ibyza-api.onrender.com,ibyzacorp.com,www.ibyzacorp.com
ALLOWED_HOSTS=localhost,127.0.0.1


# ─── Base de datos ───────────────────────────────────────────────────────────
# Vacío → usa SQLite local (db.sqlite3).
# Render/Railway generan DATABASE_URL automáticamente al crear la DB.
DATABASE_URL=


# ─── CORS (frontend) ─────────────────────────────────────────────────────────
# Producción: https://ibyza-web.vercel.app,https://ibyzacorp.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000


# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Plan gratuito: 3000 emails/mes. Crear API key en https://resend.com/api-keys
# Sin API key: en DEBUG=True imprime emails en consola; en producción solo loguea error.
RESEND_API_KEY=

# Dominio "from". Por defecto el de prueba de Resend (no requiere DNS).
# Cuando IBYZA verifique ibyzacorp.com en Resend, cambiar a:
#   RESEND_FROM_EMAIL=IBYZA <no-reply@ibyzacorp.com>
RESEND_FROM_EMAIL=IBYZA <onboarding@resend.dev>

# Destinatarios de notificaciones (formularios y citas), separados por coma.
# Hasta verificar el dominio, Resend solo permite enviar al email de la cuenta.
EMAIL_RECIPIENTS=destinatario1@email.com,destinatario2@email.com


# ─── Culqi (Pasarela de pago) ────────────────────────────────────────────────
# Obtener credenciales en https://panel.culqi.com (Configuración → Llaves API).
# Usar las "test" para pruebas y las "live" para producción real.
CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx


# ─── Admin (superusuario inicial automático) ─────────────────────────────────
# El comando `python manage.py create_admin` crea el superusuario solo si
# no existe. Se ejecuta automáticamente al hacer deploy.
# Dejar vacío DJANGO_SUPERUSER_PASSWORD para omitir la creación.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ibyzacorp.com
DJANGO_SUPERUSER_PASSWORD=
